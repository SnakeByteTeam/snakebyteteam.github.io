							"font": "Arial;13;0",
							"parentStyle": false,
							"containerChangeable": true,
							"left": 1471,
							"top": 907,
							"width": 72.09912109375,
							"height": 58,
							"nameCompartment": {
								"$ref": "AAAAAAGczIUXJKoReIw="
							},
							"attributeCompartment": {
								"$ref": "AAAAAAGczIUXJKoWMf8="
							},
							"operationCompartment": {
								"$ref": "AAAAAAGczIUXJKoXf9M="
