							"points": "2300:881;2368:886"
						},
						{
							"_type": "UMLNoteView",
							"_id": "AAAAAAGcx1nlOE6Btpw=",
							"_parent": {
								"$ref": "AAAAAAGcw97/Uq3cgA8="
							},
							"font": "Arial;13;0",
							"parentStyle": false,
							"left": 1616,
							"top": 1208,
							"width": 206.13916015625,
							"height": 77,
							"text": "raggruppa tutte le feature di gestione utenti"
						},
						{
							"_type": "UMLNoteLinkView",
							"_id": "AAAAAAGcx1nlQU6rLpk=",
							"_parent": {
								"$ref": "AAAAAAGcw97/Uq3cgA8="
							},
							"font": "Arial;13;0",
							"parentStyle": false,
							"head": {
								"$ref": "AAAAAAGcx1nlOE6Btpw="
							},
							"tail": {
								"$ref": "AAAAAAGcw97/V656n00="
							},
							"lineStyle": 1,
							"points": "1525:1206;1615:1225"
						},
						{
							"_type": "UMLNoteView",
							"_id": "AAAAAAGcx1tyX3W0hKc=",
							"_parent": {
								"$ref": "AAAAAAGcw97/Uq3cgA8="
							},
							"font": "Arial;13;0",
							"parentStyle": false,
							"left": 1242.95361328125,
							"top": 1280,
							"width": 205.04638671875,
							"height": 81,
							"text": "Array di routes Angular.\n\n(Le route vengono già protette a livello di Auth) => non definisce Guard propri, riutilizza quelli di Auth"
						},
						{
							"_type": "UMLNoteLinkView",
							"_id": "AAAAAAGcx1tybHXeW+E=",
							"_parent": {
								"$ref": "AAAAAAGcw97/Uq3cgA8="
							},
							"font": "Arial;13;0",
							"parentStyle": false,
							"head": {
								"$ref": "AAAAAAGcx1tyX3W0hKc="
							},
							"tail": {
								"$ref": "AAAAAAGcw97/V66Gb3A="
							},
							"lineStyle": 1,
							"points": "1174:1317;1242:1318"
						},
						{
							"_type": "UMLNoteView",
							"_id": "AAAAAAGcx16bSIXmcmA=",
							"_parent": {
								"$ref": "AAAAAAGcw97/Uq3cgA8="
							},
							"font": "Arial;13;0",
							"parentStyle": false,
							"left": 352,
							"top": 912,
							"width": 424,
							"height": 176,
							"text": "Perché NON ci sono campi UserListComponent, CreateUserFormComponent, UserCreatedDialogComponent:\n\nIn Angular, il pattern Smart/Dumb non usa @ViewChild per tenere riferimenti ai figli come campi TypeScript. La comunicazione avviene esclusivamente attraverso i binding del template ([input] e (output)). \n\nIl componente parent non \"possiede\" i figli come oggetti — li dichiara nel template HTML e Angular ne gestisce il ciclo di vita tramite il DOM.\nQuindi la composizione *-- in UML è semanticamente corretta (il parent controlla il ciclo di vita dei figli), ma non si traduce in campi TypeScript. È una relazione di template, non di campo.\n"
						},
						{
							"_type": "UMLNoteLinkView",
							"_id": "AAAAAAGcx16bVIYQQEc=",
							"_parent": {
								"$ref": "AAAAAAGcw97/Uq3cgA8="
							},
							"font": "Arial;13;0",
							"parentStyle": false,
							"head": {
								"$ref": "AAAAAAGcx16bSIXmcmA="
							},
							"tail": {
								"$ref": "AAAAAAGcw97/Vq5BsBg="
							},
							"lineStyle": 1,
							"points": "1287:937;777:982"
						}
					]
				},
