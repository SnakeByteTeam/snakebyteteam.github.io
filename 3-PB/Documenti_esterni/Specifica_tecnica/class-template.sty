%        \noindent
%        \textbf{Descrizione degli attributi della classe:}
%        \begin{itemize}
%            \listaAttributi
%        \end{itemize}
%    }
    \ifdefempty{\listaMetodi}{}{
        \noindent
        \textbf{Descrizione dei metodi della classe:}
        \begin{itemize}
            \listaMetodi
        \end{itemize}
    }

    % Pulisce le variabili
    \renewcommand{\listaMetodi}{}
    \renewcommand{\listaAttributi}{}
    \renewcommand{\listaAttrGra}{}
    \renewcommand{\listaMetGra}{}
}


