        draw,
        rectangle,
        inner sep=4pt,
        text width=10cm % <-- fondamentale
    ] {
    \centering
    \textbf{#1}

    \par\noindent\rule{\textwidth}{0.4pt}

    \raggedright
    \listaAttrGra

    \par\noindent\rule{\textwidth}{0.4pt}

    \listaMetGra
